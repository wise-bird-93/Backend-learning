<%- include('../partials/head') %>
</head>

<body>

<%- include('../partials/nav') %>

<main class="max-w-7xl mx-auto px-6 py-10">

    <h2 class="text-3xl font-bold text-center text-red-500 mb-10">
        Explore Homes
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

        <% registeredHomes.forEach(home => { %>

        <a href="/viewHome/<%= home.id %>"
   class="block w-fit mx-auto bg-gray-50 border border-gray-300 rounded-2xl p-4 shadow-lg hover:shadow-2xl hover:border-red-500 transition-all duration-300">

    <img
        src="<%= home.photoURL %>"
        class="mx-auto"
        style="width:300px;height:180px;object-fit:cover;border-radius:12px;"
    >

    <h3 class="mt-4 text-2xl font-bold text-center text-gray-800 hover:text-red-500 transition">
        <%= home.houseName %>
    </h3>

</a>

        <% }) %>

    </div>

</main>

</body>

</html>